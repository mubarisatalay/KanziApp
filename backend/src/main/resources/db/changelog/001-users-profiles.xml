<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- gen_random_uuid() is core in PG13+, but pgcrypto guarantees it cross-version -->
    <changeSet id="000-pgcrypto" author="kaan.kahveci">
        <sql>CREATE EXTENSION IF NOT EXISTS pgcrypto;</sql>
        <rollback>DROP EXTENSION IF EXISTS pgcrypto;</rollback>
    </changeSet>

    <!--
      Single table that owns BOTH authentication and profile data.
      Replaces Supabase auth.users + public.profiles (no more auth.users FK coupling).
    -->
    <changeSet id="001-create-users" author="kaan.kahveci">
        <createTable tableName="users">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="TEXT">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_users_email"/>
            </column>
            <column name="password_hash" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="email_verified" type="BOOLEAN" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="verification_token" type="TEXT"/>
            <column name="username" type="TEXT">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_users_username"/>
            </column>
            <column name="display_name" type="TEXT"/>
            <column name="avatar_url" type="TEXT"/>
            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
